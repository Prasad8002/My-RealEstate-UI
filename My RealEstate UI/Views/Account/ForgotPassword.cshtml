@model My_RealEstate_UI.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-page auth-page--centered">
    <div class="auth-form-wrap auth-form-wrap--solo">

        <a href="@Url.Action("Index","Home")" class="auth-logo">
            <span class="brand-icon">D</span>wello
        </a>

        <div class="auth-icon-circle">
            <i class="fa-solid fa-key"></i>
        </div>

        <h1 class="auth-form__title">Forgot your password?</h1>
        <p class="auth-form__subtitle">
            No worries! Enter your email and we'll send you a reset link.
        </p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert--success">
                <i class="fa-solid fa-circle-check"></i>
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert--error">
                <i class="fa-solid fa-circle-exclamation"></i>
                @TempData["Error"]
            </div>
        }

        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @class = "auth-form" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                @Html.LabelFor(m => m.Email, "Email Address")
                <div class="input-wrap">
                    <i class="fa-regular fa-envelope"></i>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "you@example.com", type = "email" })
                </div>
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
            </div>

            <button type="submit" class="btn btn--dark btn--full">
                Send Reset Link <i class="fa-solid fa-paper-plane"></i>
            </button>
        }

        <p class="auth-switch" style="margin-top:24px;">
            <a href="@Url.Action("Login","Account")">
                <i class="fa-solid fa-arrow-left"></i> Back to Sign In
            </a>
        </p>

    </div>
</section>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
