@model My_RealEstate_UI.Models.RegisterViewModel
@{
    ViewBag.Title = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-page">
    <div class="auth-page__split">

        <!-- ── LEFT PANEL ── -->
        <div class="auth-page__left">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=900&q=80"
                 alt="Beautiful property" class="auth-page__bg-img" />
            <div class="auth-page__overlay">
                <div class="auth-page__quote">
                    <h2>"Find your perfect home with expert guidance"</h2>
                    <p>Create a free account and start exploring thousands of premium properties today.</p>
                    <div class="auth-page__stats">
                        <div><strong>8K+</strong><span>Properties</span></div>
                        <div><strong>2K+</strong><span>Agents</span></div>
                        <div><strong>6K+</strong><span>Sold</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── RIGHT PANEL ── -->
        <div class="auth-page__right">
            <div class="auth-form-wrap">

                <a href="@Url.Action("Index","Home")" class="auth-logo">
                    <span class="brand-icon">D</span>wello
                </a>

                <h1 class="auth-form__title">Create your account</h1>
                <p class="auth-form__subtitle">Start your journey to finding your dream home</p>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert--error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        @TempData["Error"]
                    </div>
                }

                @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "auth-form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-row-half">
                        <div class="form-group">
                            @Html.LabelFor(m => m.FirstName, "First Name")
                            <div class="input-wrap">
                                <i class="fa-regular fa-user"></i>
                                @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "John" })
                            </div>
                            @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "field-error" })
                        </div>
                        <div class="form-group">
                            @Html.LabelFor(m => m.LastName, "Last Name")
                            <div class="input-wrap">
                                <i class="fa-regular fa-user"></i>
                                @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Doe" })
                            </div>
                            @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "field-error" })
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Email, "Email Address")
                        <div class="input-wrap">
                            <i class="fa-regular fa-envelope"></i>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "you@example.com", type = "email" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Phone, "Phone Number")
                        <div class="input-wrap">
                            <i class="fa-solid fa-phone"></i>
                            @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "+1 (555) 000-0000", type = "tel" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "field-error" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Password, "Password")
                        <div class="input-wrap">
                            <i class="fa-solid fa-lock"></i>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Min. 8 characters", id = "regPassword" })
                            <button type="button" class="toggle-pw" onclick="togglePassword('regPassword', this)" tabindex="-1">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
                        <!-- Password strength bar -->
                        <div class="pw-strength" id="pwStrength">
                            <div class="pw-strength__bar" id="pwBar"></div>
                        </div>
                        <span class="pw-strength__label" id="pwLabel"></span>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.ConfirmPassword, "Confirm Password")
                        <div class="input-wrap">
                            <i class="fa-solid fa-lock"></i>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Re-enter your password", id = "confirmPassword" })
                            <button type="button" class="toggle-pw" onclick="togglePassword('confirmPassword', this)" tabindex="-1">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
                    </div>

                    <div class="form-group">
                        <label class="checkbox-label">
                            @Html.CheckBoxFor(m => m.AgreeToTerms)
                            <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
                        </label>
                        @Html.ValidationMessageFor(m => m.AgreeToTerms, "", new { @class = "field-error" })
                    </div>

                    <button type="submit" class="btn btn--dark btn--full">
                        Create Account <i class="fa-solid fa-arrow-right"></i>
                    </button>
                }

                <div class="auth-divider"><span>or sign up with</span></div>

                <div class="social-btns">
                    <button class="social-btn">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" width="20" />
                        Google
                    </button>
                    <button class="social-btn">
                        <img src="https://www.svgrepo.com/show/448234/facebook.svg" alt="Facebook" width="20" />
                        Facebook
                    </button>
                </div>

                <p class="auth-switch">
                    Already have an account?
                    <a href="@Url.Action("Login","Account")">Sign in</a>
                </p>

            </div>
        </div>

    </div>
</section>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>function togglePassword(fieldId, btn) {
            var field = document.getElementById(fieldId);
            var icon  = btn.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.className = 'fa-regular fa-eye-slash';
            } else {
                field.type = 'password';
                icon.className = 'fa-regular fa-eye';
            }
        }

        // Password strength meter
        document.getElementById('regPassword').addEventListener('input', function () {
            var val   = this.value;
            var bar   = document.getElementById('pwBar');
            var label = document.getElementById('pwLabel');
            var score = 0;

            if (val.length >= 8)              score++;
            if (/[A-Z]/.test(val))            score++;
            if (/[0-9]/.test(val))            score++;
            if (/[^A-Za-z0-9]/.test(val))     score++;

            var levels = [
                { pct: '25%',  color: '#e74c3c', text: 'Weak' },
                { pct: '50%',  color: '#e67e22', text: 'Fair' },
                { pct: '75%',  color: '#f1c40f', text: 'Good' },
                { pct: '100%', color: '#27ae60', text: 'Strong' }
            ];

            if (val.length === 0) {
                bar.style.width = '0';
                label.textContent = '';
                return;
            }

            var l = levels[score - 1] || levels[0];
            bar.style.width    = l.pct;
            bar.style.background = l.color;
            label.textContent  = l.text;
            label.style.color  = l.color;
        });</script>
}
