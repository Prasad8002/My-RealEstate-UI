<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - RealEstate</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="@Url.Content("~/Content/site.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/auth.css")" />
    @RenderSection("styles", required: false)
</head>
<body>

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar">
        <div class="container navbar__inner">
            <a href="@Url.Action("Index","Home")" class="navbar__brand">
                <span class="brand-icon">R</span>ealEstate
            </a>
            <ul class="navbar__menu">
                <li><a href="@Url.Action("Index","Home")" class="@(ViewBag.ActivePage == "Home" ? "active" : "")">Home</a></li>
                <li><a href="@Url.Action("Service","Home")" class="@(ViewBag.ActivePage == "Service" ? "active" : "")">Service</a></li>
                <li><a href="@Url.Action("Agents","Home")" class="@(ViewBag.ActivePage == "Agents" ? "active" : "")">Agents</a></li>
                <li><a href="@Url.Action("Contact","Home")" class="@(ViewBag.ActivePage == "Contact" ? "active" : "")">Contact</a></li>
            </ul>
            <div class="navbar__actions">
                <button class="icon-btn" aria-label="Search"><i class="fa-solid fa-magnifying-glass"></i></button>
                <button class="icon-btn" aria-label="Account"><i class="fa-regular fa-user"></i></button>
                <a href="@Url.Action("Register","Account")" class="btn btn--dark">Sign up</a>
            </div>
            <!-- Mobile hamburger -->
            <button class="navbar__hamburger" id="hamburgerBtn" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </button>
        </div>
        <!-- Mobile menu -->
        <div class="navbar__mobile" id="mobileMenu">
            <ul>
                <li><a href="@Url.Action("Index","Home")">Home</a></li>
                <li><a href="@Url.Action("Service","Home")">Service</a></li>
                <li><a href="@Url.Action("Agents","Home")">Agents</a></li>
                <li><a href="@Url.Action("Contact","Home")">Contact</a></li>
                <li><a href="@Url.Action("Register","Account")" class="btn btn--dark" style="display:inline-block;margin-top:8px;">Sign up</a></li>
            </ul>
        </div>
    </nav>

    <!-- ========== MAIN CONTENT ========== -->
    <main>
        @RenderBody()
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="footer">
        <!-- CTA Band -->
        <div class="footer__cta">
            <h2>Do You Have Any Questions?<br />Get Help From Us</h2>
            <div class="footer__cta-links">
                <span><i class="fa-regular fa-circle-check"></i> Chat live with our support team</span>
                <span><i class="fa-regular fa-circle-check"></i> Browse our FAQ</span>
            </div>
            <div class="footer__cta-form">
                @using (Html.BeginForm("Subscribe", "Home", FormMethod.Post, new { @class = "cta-form" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="email" name="email" placeholder="Enter your email address..." class="cta-input" required />
                    <button type="submit" class="btn btn--dark">Submit</button>
                }
            </div>
        </div>

        <!-- Footer Links -->
        <div class="footer__main">
            <div class="container footer__grid">
                <!-- Brand -->
                <div class="footer__brand">
                    <div class="footer__logo">
                        <span class="brand-icon brand-icon--sm">D</span>wello
                    </div>
                    <p>Bringing you closer to your dream home, one click at a time.</p>
                </div>

                <!-- About -->
                <div class="footer__col">
                    <h4>About</h4>
                    <ul>
                        <li><a href="#">Our Story</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Our Team</a></li>
                        <li><a href="#">Resources</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="footer__col">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">FAQ</a></li>
                        <li><a href="#">Contact Us</a></li>
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Terms of Service</a></li>
                    </ul>
                </div>

                <!-- Find Us -->
                <div class="footer__col">
                    <h4>Find Us</h4>
                    <ul>
                        <li><a href="#">Events</a></li>
                        <li><a href="#">Locations</a></li>
                        <li><a href="#">Newsletter</a></li>
                    </ul>
                </div>

                <!-- Social -->
                <div class="footer__col">
                    <h4>Our Social</h4>
                    <ul>
                        <li><a href="#"><i class="fa-brands fa-instagram"></i> Instagram</a></li>
                        <li><a href="#"><i class="fa-brands fa-facebook-f"></i> Facebook</a></li>
                        <li><a href="#"><i class="fa-brands fa-x-twitter"></i> Twitter (x)</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <!-- jQuery (for .NET MVC unobtrusive validation) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="@Url.Content("~/Scripts/site.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
